  { id:'vs800', name:'Suzuki V-Strom 800 DE', tag:'Global Adventure Tourer', price:'₹11.88 Lakh*', cc:'776cc', power:'84.3 PS', torque:'78 Nm', mileage:'23 kmpl', badge:'ADV', desc:'Wire-spoked adventure tourer with adjustable suspension, cruise control and off-road ABS.', img:'images/vstrom800.png' },
  { id:'ffv', name:'Gixxer SF 250 Flex Fuel', tag:'Eco-Friendly Performance', price:'₹2.32 Lakh*', cc:'250cc', power:'27.9 PS', torque:'23 Nm', mileage:'33 kmpl', badge:'E85', desc:"World's first flex-fuel sports bike. Runs on E85 ethanol blend for cleaner, powerful riding.", img:'images/sf250flex.png' }
];

let current = bikes[0];

function loadBike(b) {
  current = b;
  const img = document.getElementById('bikeMainImg');
  
  img.style.opacity = '0';
  
  document.getElementById('vName').textContent = b.name;
  document.getElementById('vTag').textContent = b.tag;
  document.getElementById('vPrice').textContent = b.price;
  
  const specsHtml = `
    <div class="spec-chip"><div class="spec-key">Engine</div><div class="spec-val">${b.cc}</div></div>
    <div class="spec-chip"><div class="spec-key">Power</div><div class="spec-val">${b.power}</div></div>
    <div class="spec-chip"><div class="spec-key">Torque</div><div class="spec-val">${b.torque}</div></div>
    <div class="spec-chip"><div class="spec-key">Mileage</div><div class="spec-val">${b.mileage}</div></div>
  `;
  document.getElementById('vSpecs').innerHTML = specsHtml;

  img.src = b.img;
  img.onload = () => { img.style.opacity = '1'; };
  img.onerror = () => { 
    console.error("Image failed to load. Make sure the file exists in the images folder:", b.img);
    img.style.opacity = '1';
  };

  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  const activeThumb = document.getElementById(`thumb-${b.id}`);
  if (activeThumb) activeThumb.classList.add('active');
}

function initUI() {
  const thumbRow = document.getElementById('thumbRow');
  const bikesGrid = document.getElementById('bikesGrid');
  
  let thumbsHtml = '';
  let gridHtml = '';

  bikes.forEach((b, index) => {
    thumbsHtml += `
      <div class="thumb ${index === 0 ? 'active' : ''}" id="thumb-${b.id}" onclick="loadBike(bikes.find(x => x.id === '${b.id}'))">
        <img src="${b.img}" alt="${b.name}">
        <div class="thumb-name">${b.name.replace('Suzuki ', '')}</div>
        <div class="thumb-cc">${b.cc}</div>
      </div>
    `;

    gridHtml += `
      <div class="bike-card" onclick="document.getElementById('hero').scrollIntoView(); loadBike(bikes.find(x => x.id === '${b.id}'))">
        ${b.badge ? `<div class="card-tag">${b.badge}</div>` : ''}
        <div class="card-img"><img src="${b.img}" alt="${b.name}" loading="lazy"></div>
        <div class="card-body">
          <div class="card-name">${b.name}</div>
          <div class="card-cc">${b.cc} | ${b.power}</div>
          <div class="card-price">${b.price}</div>
          <div class="card-desc">${b.desc}</div>
        </div>
      </div>
    `;
  });

  thumbRow.innerHTML = thumbsHtml;
  bikesGrid.innerHTML = gridHtml;
}

const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.15 });

document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

initUI();
loadBike(bikes[0]);

</script>
</body>
</html>
